generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LaporanStatus {
  pending
  verified
  in_progress
  clarification_requested
  resolved
  rejected
}

enum LaporanRoutingStatus {
  pending
  auto_assigned
  manual_review
  manually_assigned
  failed
}

enum NotificationType {
  success
  warning
  danger
  info
}

enum Stsrc {
  A
  U
  D
}

model MsUser {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String    @default("warga")
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  phone         String?
  lastLoginAt   DateTime?

  sessions        TrSession[]
  accounts        MsAccount[]
  createdReports  TrLaporan[]       @relation("ReportCreator")
  assignedReports TrLaporan[]       @relation("ReportAssignee")
  resolvedReports TrLaporan[]       @relation("ReportResolver")
  reportVotes     TrLaporanVote[]
  reportRatings   TrLaporanRating[]
  petugas         MsPetugasDinas?
  notifications   TrNotification[]

  @@map("MsUser")
}

model TrSession {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      MsUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("TrSession")
}

model MsAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  MsUser    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("MsAccount")
}

model TrVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("TrVerification")
}

model MsDinas {
  id              String  @id @default(cuid())
  code            String  @unique
  type            String  @default("")
  name            String
  short           String
  wilayah         String?
  description     String?
  isActive        Boolean @default(true)
  routingPriority Int     @default(100)
  stsrc           Stsrc   @default(A)

  kategori         MsKategoriLaporan[]
  cabang           MsCabangDinas[]
  ratings          TrLaporanRating[]
  routingDecisions TrLaporanRoutingDecision[]

  @@index([type, wilayah])
  @@index([isActive, routingPriority])
  @@index([stsrc])
  @@map("MsDinas")
}

model MsCabangDinas {
  id               String   @id @default(cuid())
  name             String
  wilayah          String
  address          String?
  latitude         Float?
  longitude        Float?
  phone            String?
  province         String?
  cityRegency      String?
  coverageRadiusKm Int?
  isRoutingEnabled Boolean  @default(true)
  serviceTags      String[] @default([])
  photos           String[] @default([])
  metadata         Json?
  stsrc            Stsrc    @default(A)

  dinasId String
  dinas   MsDinas @relation(fields: [dinasId], references: [id])

  petugas          MsPetugasDinas[]
  laporan          TrLaporan[]
  ratings          TrLaporanRating[]
  routingDecisions TrLaporanRoutingDecision[]

  @@index([dinasId, wilayah])
  @@index([cityRegency, isRoutingEnabled])
  @@index([latitude, longitude])
  @@index([stsrc])
  @@map("MsCabangDinas")
}

model MsKategoriLaporan {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  slaHours      Int?
  urgencyWeight Int      @default(50)
  keywords      String[] @default([])
  isActive      Boolean  @default(true)
  stsrc         Stsrc    @default(A)
  dinasId       String
  dinas         MsDinas  @relation(fields: [dinasId], references: [id])

  laporan          TrLaporan[]
  routingDecisions TrLaporanRoutingDecision[]

  @@index([dinasId, isActive])
  @@index([stsrc])
  @@map("MsKategoriLaporan")
}

model TrLaporan {
  id                     String               @id @default(cuid())
  title                  String
  description            String
  status                 LaporanStatus        @default(pending)
  routingStatus          LaporanRoutingStatus @default(pending)
  images                 String[]
  latitude               Float
  longitude              Float
  address                String?
  kategoriId             String?
  cabangDinasId          String?
  createdById            String
  assignedToId           String?
  resolvedById           String?
  aiDecisionStatus       String?
  aiRejectionCode        String?
  aiSuggestedRewrite     String?
  aiClarityScore         Int?
  aiSeriousnessScore     Int?
  aiConfidence           Float?
  aiReasoning            String?
  aiClassified           Boolean              @default(false)
  aiUrgencyScore         Int?
  aiSuggestedSlaHours    Int?
  aiAssignedBranchReason String?
  aiRouteMeta            Json?
  agencyNote             String?
  resolutionNote         String?
  resolutionImages       String[]             @default([])
  resolvedAt             DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  stsrc                  Stsrc                @default(A)

  kategori    MsKategoriLaporan? @relation(fields: [kategoriId], references: [id], onDelete: SetNull)
  cabangDinas MsCabangDinas?     @relation(fields: [cabangDinasId], references: [id])
  createdBy   MsUser             @relation("ReportCreator", fields: [createdById], references: [id])
  assignedTo  MsUser?            @relation("ReportAssignee", fields: [assignedToId], references: [id])
  resolvedBy  MsUser?            @relation("ReportResolver", fields: [resolvedById], references: [id])

  notifications    TrNotification[]
  routingDecisions TrLaporanRoutingDecision[]
  timeline         TrLaporanTimeline[]
  votes            TrLaporanVote[]
  rating           TrLaporanRating?

  @@index([createdById])
  @@index([kategoriId, status])
  @@index([cabangDinasId, status])
  @@index([routingStatus, createdAt])
  @@index([latitude, longitude])
  @@index([stsrc])
  @@map("TrLaporan")
}

model TrLaporanVote {
  id        String   @id @default(cuid())
  laporanId String
  userId    String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  laporan TrLaporan @relation(fields: [laporanId], references: [id], onDelete: Cascade)
  user    MsUser    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([laporanId, userId])
  @@index([userId])
  @@map("TrLaporanVote")
}

model TrLaporanRating {
  id            String   @id @default(cuid())
  laporanId     String   @unique
  userId        String
  dinasId       String?
  cabangDinasId String?
  score         Int
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  laporan     TrLaporan       @relation(fields: [laporanId], references: [id], onDelete: Cascade)
  user        MsUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dinas       MsDinas?        @relation(fields: [dinasId], references: [id], onDelete: SetNull)
  cabangDinas MsCabangDinas?  @relation(fields: [cabangDinasId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([dinasId])
  @@index([cabangDinasId])
  @@map("TrLaporanRating")
}

model TrLaporanTimeline {
  id        String        @id @default(cuid())
  laporanId String
  status    LaporanStatus
  note      String?
  images    String[]      @default([])
  actorId   String?
  actorRole String?
  createdAt DateTime      @default(now())

  laporan TrLaporan @relation(fields: [laporanId], references: [id], onDelete: Cascade)

  @@index([laporanId, createdAt])
  @@map("TrLaporanTimeline")
}

model TrLaporanRoutingDecision {
  id                String   @id @default(cuid())
  laporanId         String
  kategoriId        String?
  dinasId           String?
  cabangDinasId     String?
  source            String   @default("ai")
  confidence        Float?
  urgencyScore      Int?
  suggestedSlaHours Int?
  distanceKm        Float?
  wilayahMatched    String?
  reasoning         String?
  candidateCabang   Json?
  createdAt         DateTime @default(now())

  laporan     TrLaporan          @relation(fields: [laporanId], references: [id], onDelete: Cascade)
  kategori    MsKategoriLaporan? @relation(fields: [kategoriId], references: [id], onDelete: SetNull)
  dinas       MsDinas?           @relation(fields: [dinasId], references: [id], onDelete: SetNull)
  cabangDinas MsCabangDinas?     @relation(fields: [cabangDinasId], references: [id], onDelete: SetNull)

  @@index([laporanId, createdAt])
  @@index([dinasId, createdAt])
  @@index([cabangDinasId, createdAt])
  @@map("TrLaporanRoutingDecision")
}

model TrNotification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  tag         String
  isRead      Boolean          @default(false)
  readAt      DateTime?
  deliveredAt DateTime?
  metadata    Json?
  userId      String
  laporanId   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt

  user    MsUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  laporan TrLaporan? @relation(fields: [laporanId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("TrNotification")
}

model MsPetugasDinas {
  id            String      @id @default(cuid())
  nip           String      @unique
  userId        String      @unique
  user          MsUser      @relation(fields: [userId], references: [id])
  cabangDinasId String
  cabangDinas   MsCabangDinas @relation(fields: [cabangDinasId], references: [id])

  @@map("MsPetugasDinas")
}
