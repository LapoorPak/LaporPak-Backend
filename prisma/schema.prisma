generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LaporanStatus {
  pending
  verified
  in_progress
  clarification_requested
  resolved
  rejected
}

enum LaporanRoutingStatus {
  pending
  auto_assigned
  manual_review
  manually_assigned
  failed
}

enum NotificationType {
  success
  warning
  danger
  info
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String    @default("warga")
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  phone         String?

  sessions        Session[]
  accounts        Account[]
  createdReports  Laporan[]      @relation("ReportCreator")
  assignedReports Laporan[]      @relation("ReportAssignee")
  resolvedReports Laporan[]      @relation("ReportResolver")
  petugas         PetugasDinas?
  notifications   Notification[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Dinas {
  id              String                   @id @default(cuid())
  code            String                   @unique
  type            String                   @default("")
  name            String
  short           String
  wilayah         String?
  description     String?
  isActive        Boolean                  @default(true)
  routingPriority Int                      @default(100)

  kategori         KategoriLaporan[]
  cabang           CabangDinas[]
  routingDecisions LaporanRoutingDecision[]

  @@index([type, wilayah])
  @@index([isActive, routingPriority])
  @@map("dinas")
}

model CabangDinas {
  id               String                   @id @default(cuid())
  name             String
  wilayah          String
  address          String?
  latitude         Float?
  longitude        Float?
  phone            String?
  province         String?
  cityRegency      String?
  coverageRadiusKm Int?
  isRoutingEnabled Boolean                  @default(true)
  serviceTags      String[]                 @default([])
  photos           String[]                 @default([])
  metadata         Json?

  dinasId String
  dinas   Dinas @relation(fields: [dinasId], references: [id])

  petugas          PetugasDinas[]
  laporan          Laporan[]
  routingDecisions LaporanRoutingDecision[]

  @@index([dinasId, wilayah])
  @@index([cityRegency, isRoutingEnabled])
  @@index([latitude, longitude])
  @@map("cabang_dinas")
}

model KategoriLaporan {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  slaHours      Int?
  urgencyWeight Int      @default(50)
  keywords      String[] @default([])
  isActive      Boolean  @default(true)
  dinasId       String
  dinas         Dinas    @relation(fields: [dinasId], references: [id])

  laporan          Laporan[]
  routingDecisions LaporanRoutingDecision[]

  @@index([dinasId, isActive])
  @@map("kategori_laporan")
}

model Laporan {
  id                    String               @id @default(cuid())
  title                 String
  description           String
  status                LaporanStatus        @default(pending)
  routingStatus         LaporanRoutingStatus @default(pending)
  images                String[]
  latitude              Float
  longitude             Float
  address               String?
  kategoriId            String?
  cabangDinasId         String?
  createdById           String
  assignedToId          String?
  resolvedById          String?
  aiDecisionStatus      String?
  aiRejectionCode       String?
  aiSuggestedRewrite    String?
  aiClarityScore        Int?
  aiSeriousnessScore    Int?
  aiConfidence          Float?
  aiReasoning           String?
  aiClassified          Boolean              @default(false)
  aiUrgencyScore        Int?
  aiSuggestedSlaHours   Int?
  aiAssignedBranchReason String?
  aiRouteMeta           Json?
  agencyNote            String?
  resolutionNote        String?
  resolutionImages      String[]             @default([])
  resolvedAt            DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  kategori    KategoriLaporan? @relation(fields: [kategoriId], references: [id], onDelete: SetNull)
  cabangDinas CabangDinas?    @relation(fields: [cabangDinasId], references: [id])
  createdBy   User            @relation("ReportCreator", fields: [createdById], references: [id])
  assignedTo  User?           @relation("ReportAssignee", fields: [assignedToId], references: [id])
  resolvedBy  User?           @relation("ReportResolver", fields: [resolvedById], references: [id])

  notifications   Notification[]
  routingDecisions LaporanRoutingDecision[]
  timeline         LaporanTimeline[]

  @@index([createdById])
  @@index([kategoriId, status])
  @@index([cabangDinasId, status])
  @@index([routingStatus, createdAt])
  @@index([latitude, longitude])
  @@map("laporan")
}

model LaporanTimeline {
  id        String        @id @default(cuid())
  laporanId String
  status    LaporanStatus
  note      String?
  images    String[]      @default([])
  actorId   String?
  actorRole String?
  createdAt DateTime      @default(now())

  laporan Laporan @relation(fields: [laporanId], references: [id], onDelete: Cascade)

  @@index([laporanId, createdAt])
  @@map("laporan_timeline")
}

model LaporanRoutingDecision {
  id               String           @id @default(cuid())
  laporanId        String
  kategoriId       String?
  dinasId          String?
  cabangDinasId    String?
  source           String           @default("ai")
  confidence       Float?
  urgencyScore     Int?
  suggestedSlaHours Int?
  distanceKm       Float?
  wilayahMatched   String?
  reasoning        String?
  candidateCabang  Json?
  createdAt        DateTime         @default(now())

  laporan     Laporan          @relation(fields: [laporanId], references: [id], onDelete: Cascade)
  kategori    KategoriLaporan? @relation(fields: [kategoriId], references: [id], onDelete: SetNull)
  dinas       Dinas?           @relation(fields: [dinasId], references: [id], onDelete: SetNull)
  cabangDinas CabangDinas?     @relation(fields: [cabangDinasId], references: [id], onDelete: SetNull)

  @@index([laporanId, createdAt])
  @@index([dinasId, createdAt])
  @@index([cabangDinasId, createdAt])
  @@map("laporan_routing_decision")
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  tag         String
  isRead      Boolean          @default(false)
  readAt      DateTime?
  deliveredAt DateTime?
  metadata    Json?
  userId      String
  laporanId   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  laporan Laporan? @relation(fields: [laporanId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notification")
}

model PetugasDinas {
  id            String      @id @default(cuid())
  nip           String      @unique
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id])
  cabangDinasId String
  cabangDinas   CabangDinas @relation(fields: [cabangDinasId], references: [id])

  @@map("petugas_dinas")
}
